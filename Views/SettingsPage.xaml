<Page
    x:Class="$safeprojectname$.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="12">
        <Grid Padding="20" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,16"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="設定" />
            <ScrollViewer Grid.Row="1">
                <StackPanel Spacing="12">
                    <Expander
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Header="外観とテーマ"
                        IsExpanded="True">
                        <StackPanel Spacing="10">
                            <!--  アプリのテーマ設定カード  -->
                            <Border
                                Margin="0,0,0,4"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <Grid Padding="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        HorizontalAlignment="Left"
                                        FontSize="20"
                                        Glyph="&#xE790;" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="アプリのテーマ" />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="表示するアプリのテーマを選択します" />
                                    </StackPanel>
                                    <ComboBox
                                        Grid.Column="2"
                                        Width="200"
                                        VerticalAlignment="Center"
                                        SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}">
                                        <ComboBoxItem Content="システム設定に従う" />
                                        <ComboBoxItem Content="ライト" />
                                        <ComboBoxItem Content="ダーク" />
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!--  ナビゲーションスタイル設定カード  -->
                            <Border
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <Grid Padding="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        HorizontalAlignment="Left"
                                        FontSize="20"
                                        Glyph="&#xF594;" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="ナビゲーションスタイル" />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="メニューの表示位置（左側または上部）を選択します" />
                                    </StackPanel>
                                    <ComboBox
                                        Grid.Column="2"
                                        Width="200"
                                        VerticalAlignment="Center"
                                        SelectedIndex="{x:Bind ViewModel.SelectedNavStyleIndex, Mode=TwoWay}">
                                        <ComboBoxItem Content="左側 (サイドバー)" />
                                        <ComboBoxItem Content="上部" />
                                    </ComboBox>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </Expander>
                    <Expander
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Header="AI アシスタント設定"
                        IsExpanded="True">
                        <StackPanel Spacing="12">
                            <PasswordBox
                                Header="Gemini API Key"
                                Password="{x:Bind ViewModel.GeminiApiKey, Mode=TwoWay}"
                                PasswordRevealMode="Peek"
                                PlaceholderText="ここに Google Gemini API Key を入力" />
                            <HyperlinkButton NavigateUri="https://aistudio.google.com/app/apikey">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="14" Glyph="&#xE8D7;" />
                                    <TextBlock Text="APIキーを取得する (Google AI Studio)" />
                                </StackPanel>
                            </HyperlinkButton>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
            <Button
                Grid.Row="2"
                Width="150"
                Margin="0,16,0,0"
                Command="{x:Bind ViewModel.SaveSettingsCommand}"
                Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon FontSize="16" Glyph="&#xE74E;" />
                    <TextBlock Text="設定を保存" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Page>